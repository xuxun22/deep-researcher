{
  "name": "deep-researcher",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:lib": "vitest run __tests__/lib",
    "test:core": "vitest run __tests__/core",
    "db:migrate": "npx supabase db push",
    "db:generate-types": "npx supabase gen types typescript --local > src/lib/db/types.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@supabase/supabase-js": "^2.108.2",
    "cron-parser": "^5.5.0",
    "gray-matter": "^4.0.3",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.43",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
